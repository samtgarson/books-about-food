{
  "extends": ["//"],
  "tasks": {
    "dev:jobs": {
      "cache": false,
      "persistent": true,
      "outputs": []
    },
    "dev": {
      "with": ["dev:jobs"]
    },
    "build": {
      "outputs": [".next/**"],
      "env": [
        "ADMIN_API_SECRET",
        "AUTH_SECRET",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_S3_BUCKET",
        "AWS_S3_ENDPOINT",
        "AWS_SECRET_ACCESS_KEY",
        "CRON_SECRET",
        "DATABASE_URL",
        "DATABASE_DIRECT_URL",
        "ENABLE_SPLASH",
        "GOOGLE_API_KEY",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "NEXTAUTH_SECRET",
        "NEXT_PUBLIC_MAPBOX_TOKEN",
        "POSTMARK_SERVER_TOKEN",
        "S3_DOMAIN",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SKIP_REDIS_CACHE",
        "SMTP_HOST",
        "SMTP_PASS",
        "SMTP_PORT",
        "SMTP_SECURE",
        "SMTP_USER",
        "UPSTASH_REDIS_TOKEN",
        "UPSTASH_REDIS_URL"
      ]
    }
  }
}
